{
  "name": "agent-ui-kit",
  "version": "0.1.0",
  "private": true,
  "description": "HARI — Universal Human–Agent Runtime Interface: an intent-driven, trust-aware UI architecture for agentic platforms",
  "scripts": {
    "dev": "pnpm --filter @hari/demo dev",
    "build": "pnpm --filter @hari/core build && pnpm --filter @hari/ui build && pnpm --filter @hari/demo build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "lint:fix": "eslint packages/*/src --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,json}\"",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
